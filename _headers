# Cloudflare Pages reads this file at the repo root to set HTTP response
# headers per path. Pattern matching: most-specific match wins.
#
# Reference: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Robots-Tag: noindex, nofollow, noarchive, nocache, nosnippet, noimageindex

# Long-cache everything immutable (versioned via ?v= query string in the HTML)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
/renders/*
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
/*.json
  Cache-Control: public, max-age=86400

# HTML should not be cached long — must re-fetch to pick up new builds
/
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate
